<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, viewport-fit=cover">
    
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="Пульс">
    
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 512 512'><rect width='512' height='512' rx='100' fill='%230a0a0a'/><path d='M100 256h60l30-100 40 250 50-300 40 350 40-200 40 100h60' stroke='%23e8ff47' stroke-width='30' stroke-linecap='round' stroke-linejoin='round' fill='none'/></svg>">
    <link rel="apple-touch-icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 512 512'><rect width='512' height='512' rx='100' fill='%230a0a0a'/><path d='M100 256h60l30-100 40 250 50-300 40 350 40-200 40 100h60' stroke='%23e8ff47' stroke-width='30' stroke-linecap='round' stroke-linejoin='round' fill='none'/></svg>">

    <title>ПУЛЬС</title>
    <link href="https://fonts.googleapis.com/css2?family=Unbounded:wght@400;700;900&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --bg: #0a0a0a;
            --surface: #141414;
            --surface-light: #1c1c1c;
            --border: #262626;
            --accent: #e8ff47;
            --text: #ffffff;
            --muted: #888;
            --safe-top: env(safe-area-inset-top);
            --safe-bottom: env(safe-area-inset-bottom);
        }

        * { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }
        
        body { 
            background: var(--bg); 
            color: var(--text); 
            font-family: 'Inter', sans-serif;
            line-height: 1.5;
            overflow: hidden; /* Запрет скролла всего тела для нативности */
        }

        /* Контейнер для учета Safe Areas iPhone */
        .app-wrapper {
            height: 100vh;
            display: flex;
            flex-direction: column;
            padding-top: var(--safe-top);
            padding-bottom: var(--safe-bottom);
        }

        .screen { display: none; flex: 1; flex-direction: column; overflow-y: auto; padding: 24px; animation: fadeIn 0.3s ease; }
        .screen.active { display: flex; }

        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

        /* Typography */
        h1, h2, h3 { font-family: 'Unbounded'; font-weight: 700; }
        .logo-text { font-family: 'Unbounded'; font-weight: 900; letter-spacing: -1px; }

        /* Inputs & Buttons */
        .input-group { margin-bottom: 16px; }
        .input-group label { display: block; font-size: 11px; text-transform: uppercase; color: var(--muted); margin-bottom: 6px; letter-spacing: 1px; }
        
        input {
            width: 100%; background: var(--surface); border: 1px solid var(--border);
            padding: 16px; border-radius: 14px; color: white; font-size: 16px; transition: 0.3s;
        }
        input:focus { border-color: var(--accent); outline: none; background: var(--surface-light); }

        .btn {
            width: 100%; padding: 18px; border-radius: 14px; border: none;
            font-family: 'Unbounded'; font-weight: 700; font-size: 14px;
            cursor: pointer; transition: 0.2s;
        }
        .btn-primary { background: var(--accent); color: black; }
        .btn-primary:active { transform: scale(0.98); opacity: 0.9; }
        .btn-outline { background: transparent; border: 1px solid var(--border); color: var(--text); margin-top: 12px; }

        /* Navigation */
        .bottom-nav {
            background: rgba(20, 20, 20, 0.8);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-top: 1px solid var(--border);
            display: flex;
            padding-bottom: 10px;
        }
        .nav-item {
            flex: 1; padding: 12px; text-align: center; color: var(--muted); font-size: 10px;
            display: flex; flex-direction: column; align-items: center; gap: 4px;
        }
        .nav-item.active { color: var(--accent); }
        .nav-icon { font-size: 20px; }

        /* Dashboard */
        .stat-card {
            background: var(--surface); border: 1px solid var(--border);
            padding: 20px; border-radius: 20px; flex: 1;
        }
        .stat-val { font-family: 'Unbounded'; font-size: 24px; color: var(--accent); margin-bottom: 4px; }
        .workout-row {
            background: var(--surface); padding: 16px; border-radius: 16px;
            display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;
        }

        .error-badge { background: rgba(255, 71, 71, 0.1); color: #ff4747; padding: 10px; border-radius: 10px; font-size: 12px; margin-bottom: 15px; display: none; text-align: center; }
    </style>
</head>
<body>

<div class="app-wrapper">

    <div id="screen-auth" class="screen active" style="justify-content: center;">
        <div style="text-align: center; margin-bottom: 40px;">
            <div class="logo-text" style="font-size: 36px; color: var(--accent);">ПУЛЬС</div>
            <div style="color: var(--muted); font-size: 14px;">Твой темп — твоя победа</div>
        </div>

        <div id="auth-error" class="error-badge"></div>

        <div id="box-login">
            <div class="input-group">
                <label>Email</label>
                <input type="email" id="log-email" placeholder="email@example.com">
            </div>
            <div class="input-group">
                <label>Пароль</label>
                <input type="password" id="log-pass" placeholder="••••••">
            </div>
            <button class="btn btn-primary" onclick="handleAuth('login')">ВОЙТИ</button>
            <button class="btn btn-outline" onclick="toggleAuth(true)">Создать аккаунт</button>
        </div>

        <div id="box-register" style="display: none;">
            <div class="input-group">
                <label>Как тебя зовут?</label>
                <input type="text" id="reg-name" placeholder="Твое имя">
            </div>
            <div class="input-group">
                <label>Email</label>
                <input type="email" id="reg-email" placeholder="email@example.com">
            </div>
            <div class="input-group">
                <label>Пароль</label>
                <input type="password" id="reg-pass" placeholder="Минимум 6 знаков">
            </div>
            <button class="btn btn-primary" onclick="handleAuth('register')">ЗАРЕГИСТРИРОВАТЬСЯ</button>
            <button class="btn btn-outline" onclick="toggleAuth(false)">Уже есть аккаунт</button>
        </div>
    </div>

    <div id="screen-app" class="screen">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
            <div>
                <div style="color: var(--muted); font-size: 12px;">Привет,</div>
                <h2 id="display-name">Атлет!</h2>
            </div>
            <div style="width: 44px; height: 44px; background: var(--surface); border-radius: 12px; border: 1px solid var(--border); display: flex; align-items: center; justify-content: center; color: var(--accent); font-weight: 700;" id="user-initials">А</div>
        </div>

        <div style="display: flex; gap: 12px; margin-bottom: 30px;">
            <div class="stat-card">
                <div class="stat-val" id="stat-kcal">0</div>
                <div style="font-size: 11px; color: var(--muted); text-transform: uppercase;">ккал</div>
            </div>
            <div class="stat-card">
                <div class="stat-val" id="stat-min">0</div>
                <div style="font-size: 11px; color: var(--muted); text-transform: uppercase;">минут</div>
            </div>
        </div>

        <h3 style="margin-bottom: 16px; font-size: 14px; text-transform: uppercase; letter-spacing: 1px;">Добавить активность</h3>
        <div class="workout-row" onclick="track(320, 45)">
            <div>
                <div style="font-weight: 600;">Силовая тренировка</div>
                <div style="font-size: 12px; color: var(--muted);">45 мин • 320 ккал</div>
            </div>
            <div style="color: var(--accent); font-size: 20px;">+</div>
        </div>
        <div class="workout-row" onclick="track(200, 30)">
            <div>
                <div style="font-weight: 600;">Бег / Кардио</div>
                <div style="font-size: 12px; color: var(--muted);">30 мин • 200 ккал</div>
            </div>
            <div style="color: var(--accent); font-size: 20px;">+</div>
        </div>
    </div>

    <div id="screen-profile" class="screen">
        <h2 style="margin-bottom: 24px;">Профиль</h2>
        <div class="stat-card" style="margin-bottom: 20px; text-align: center;">
            <div id="prof-email" style="color: var(--muted); font-size: 14px;">email@test.com</div>
        </div>
        <button class="btn btn-outline" style="border-color: #ff4747; color: #ff4747;" onclick="logout()">ВЫЙТИ ИЗ АККАУНТА</button>
    </div>

    <nav class="bottom-nav" id="main-nav" style="display: none;">
        <div class="nav-item active" id="nav-home" onclick="showSec('app')">
            <span class="nav-icon">🏠</span>
            <span>Главная</span>
        </div>
        <div class="nav-item" id="nav-profile" onclick="showSec('profile')">
            <span class="nav-icon">👤</span>
            <span>Профиль</span>
        </div>
    </nav>

</div>

<script>
    // ══════════════ ЛОГИКА ══════════════
    
    let db = JSON.parse(localStorage.getItem('pulse_db')) || {
        users: { "test@test.com": { name: "Атлет", pass: "123", kcal: 0, min: 0 } }
    };
    let currentUser = null;

    function save() { localStorage.setItem('pulse_db', JSON.stringify(db)); }

    function toggleAuth(isReg) {
        document.getElementById('box-login').style.display = isReg ? 'none' : 'block';
        document.getElementById('box-register').style.display = isReg ? 'block' : 'none';
        document.getElementById('auth-error').style.display = 'none';
    }

    function handleAuth(type) {
        const errorEl = document.getElementById('auth-error');
        if (type === 'login') {
            const email = document.getElementById('log-email').value.toLowerCase().trim();
            const pass = document.getElementById('log-pass').value;
            
            if (db.users[email] && db.users[email].pass === pass) {
                login(email);
            } else {
                showErr("Неверный логин или пароль");
            }
        } else {
            const name = document.getElementById('reg-name').value.trim();
            const email = document.getElementById('reg-email').value.toLowerCase().trim();
            const pass = document.getElementById('reg-pass').value;

            if (!name || !email || pass.length < 6) {
                showErr("Заполни все поля (пароль от 6 знаков)");
                return;
            }
            if (db.users[email]) {
                showErr("Этот email уже занят");
                return;
            }

            db.users[email] = { name, pass, kcal: 0, min: 0 };
            save();
            login(email);
        }
    }

    function showErr(msg) {
        const err = document.getElementById('auth-error');
        err.innerText = msg;
        err.style.display = 'block';
    }

    function login(email) {
        currentUser = email;
        const u = db.users[email];
        
        document.getElementById('display-name').innerText = u.name + '!';
        document.getElementById('user-initials').innerText = u.name[0].toUpperCase();
        document.getElementById('prof-email').innerText = email;
        document.getElementById('stat-kcal').innerText = u.kcal;
        document.getElementById('stat-min').innerText = u.min;

        document.getElementById('screen-auth').classList.remove('active');
        document.getElementById('screen-app').classList.add('active');
        document.getElementById('main-nav').style.display = 'flex';
    }

    function showSec(id) {
        document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
        document.getElementById('screen-' + id).classList.add('active');
        
        document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
        document.getElementById('nav-' + (id === 'app' ? 'home' : 'profile')).classList.add('active');
    }

    function track(k, m) {
        db.users[currentUser].kcal += k;
        db.users[currentUser].min += m;
        save();
        document.getElementById('stat-kcal').innerText = db.users[currentUser].kcal;
        document.getElementById('stat-min').innerText = db.users[currentUser].min;
        
        // Виброотклик (если поддерживается)
        if (window.navigator.vibrate) window.navigator.vibrate(50);
    }

    function logout() {
        location.reload();
    }

    // Авто-заполнение для теста
    window.onload = () => {
        document.getElementById('log-email').value = "test@test.com";
        document.getElementById('log-pass').value = "123";
    };
</script>

</body>
</html>

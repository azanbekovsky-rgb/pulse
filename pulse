<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <title>ПУЛЬС</title>
    
    <link rel="apple-touch-icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 512 512'><rect width='512' height='512' rx='100' fill='%23121212'/><path d='M120 256h60l30-100 40 250 50-300 40 350 40-200 40 100h60' stroke='%23e8ff47' stroke-width='25' stroke-linecap='round' stroke-linejoin='round' fill='none'/></svg>">

    <style>
        :root {
            --bg: #0a0a0a;
            --card: #161616;
            --accent: #e8ff47; /* Неоновый желто-зеленый */
            --text: #ffffff;
            --text-dim: #888;
        }

        body {
            margin: 0;
            background: var(--bg);
            color: var(--text);
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            display: flex;
            justify-content: center;
            height: 100vh;
            overflow: hidden;
        }

        .app-container {
            width: 100%;
            max-width: 400px;
            padding: 40px 25px;
            display: flex;
            flex-direction: column;
        }

        h1 {
            font-size: 32px;
            font-weight: 800;
            letter-spacing: -1px;
            margin: 0 0 10px 0;
            color: var(--accent);
            text-transform: uppercase;
        }

        p.subtitle {
            color: var(--text-dim);
            font-size: 14px;
            margin-bottom: 50px;
        }

        .input-group {
            margin-bottom: 25px;
        }

        label {
            display: block;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-dim);
            margin-bottom: 8px;
            margin-left: 5px;
        }

        input {
            width: 100%;
            background: var(--card);
            border: 1px solid #222;
            border-radius: 12px;
            padding: 16px;
            color: white;
            font-size: 16px;
            box-sizing: border-box;
            outline: none;
            transition: 0.3s;
        }

        input:focus {
            border-color: var(--accent);
        }

        .btn {
            background: var(--accent);
            color: black;
            border: none;
            border-radius: 12px;
            padding: 18px;
            font-size: 16px;
            font-weight: 600;
            margin-top: 20px;
            cursor: pointer;
            transition: transform 0.1s;
        }

        .btn:active {
            transform: scale(0.98);
        }

        .secondary-btn {
            background: transparent;
            color: var(--text-dim);
            font-size: 14px;
            margin-top: 20px;
            text-align: center;
            text-decoration: none;
        }
    </style>
</head>
<body>

<div class="app-container" id="auth-screen">
    <h1>Пульс</h1>
    <p class="subtitle">Минимализм в движении</p>

    <div class="input-group">
        <label>Электронная почта</label>
        <input type="email" id="email" placeholder="name@mail.com">
    </div>

    <div class="input-group">
        <label>Пароль</label>
        <input type="password" id="pass" placeholder="••••••••">
    </div>

    <button class="btn" onclick="login()">Войти</button>
    <a href="#" class="secondary-btn" onclick="toggleAuth()">Создать новый аккаунт</a>
</div>

<script>
    function login() {
        const email = document.getElementById('email').value;
        if(email) {
            alert('Добро пожаловать, ' + email);
        } else {
            alert('Введите данные для входа');
        }
    }

    function toggleAuth() {
        alert('Переход к регистрации...');
    }
</script>

</body>
</html>
